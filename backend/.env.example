# Server
PORT=5000
NODE_ENV=development

# Client (for CORS)
CLIENT_URL=http://localhost:3000

# ---------- Database ----------
# For local MongoDB this is fine as-is.
MONGO_URI=mongodb://127.0.0.1:27017/instaclone
#
# IMPORTANT if you're using MongoDB Atlas (cloud):
# The default connection string Atlas gives you starts with "mongodb+srv://".
# That "+srv" format requires your network to successfully do a DNS SRV
# lookup — and on restrictive networks (college/hostel wifi, some routers)
# that lookup fails or times out. You do NOT need to change your computer's
# DNS settings to fix this (that caused problems last time and isn't the
# right fix anyway) — just use the non-SRV connection string instead:
#   1. Atlas dashboard -> Connect -> Drivers
#   2. Click "See full connection string" / choose an older driver version
#   3. Copy the "mongodb://" string (no "+srv", lists 3 hosts explicitly)
# Example shape:
# MONGO_URI=mongodb://<user>:<password>@ac-xxxxx-shard-00-00.xxxxx.mongodb.net:27017,ac-xxxxx-shard-00-01.xxxxx.mongodb.net:27017,ac-xxxxx-shard-00-02.xxxxx.mongodb.net:27017/instaclone?ssl=true&replicaSet=atlas-xxxxx-shard-0&authSource=admin&retryWrites=true&w=majority
# The backend also retries a few times and prints a clear message if it
# detects a DNS-related connection failure — see config/db.js.

# ---------- Clerk (authentication) ----------
# Get these from https://dashboard.clerk.com -> your app -> API Keys
CLERK_SECRET_KEY=sk_test_xxx
CLERK_PUBLISHABLE_KEY=pk_test_xxx
# Dashboard -> Webhooks -> Add Endpoint -> URL: <your-backend-url>/api/webhooks/clerk
# -> Subscribe to: user.created, user.updated, user.deleted -> copy the signing secret below
CLERK_WEBHOOK_SECRET=whsec_xxx

# ---------- Cloudinary (for image uploads) ----------
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
